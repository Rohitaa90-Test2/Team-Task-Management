.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
*.sublime-project
*.sublime-workspace

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Prisma
.prisma/
prisma/migrations/

# Vite
.vite/

# Node/npm
.npm
.eslintcache
.node_repl_history
*.tgz
*.tar.gz
.yarn/install-state.gz

# Misc
.cache
*.seed
*.pid
